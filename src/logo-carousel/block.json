{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gdt-ng/logo-carousel",
	"version": "0.1.0",
	"title": "Logo Carousel",
	"category": "theme-blocks",
	"description": "A horizontally-scrolling logo carousel with the active logo centred and scaled up. Loops infinitely.",
	"example": {},
	"attributes": {
		"logos": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object"
			}
		},
		"autoPlay": {
			"type": "boolean",
			"default": true
		},
		"autoPlayDuration": {
			"type": "number",
			"default": 4
		},
		"logoGap": {
			"type": "number",
			"default": 40
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"textdomain": "cl-theme-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
